OPENAI_API_KEY=your-openai-api-key

# OpenAI models
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_LLM_MODEL=gpt-4.1-mini

# Application logging
LOG_LEVEL=INFO

# Document ingestion
DOCUMENTS_DIRECTORY=data/samples
DOCUMENT_GLOB=*.pdf
UPLOAD_DIRECTORY=data/uploads
MAX_UPLOAD_FILE_SIZE_MB=10
MAX_UPLOAD_FILES=10
CHUNK_SIZE=800
CHUNK_OVERLAP=150

# ChromaDB
CHROMA_COLLECTION_NAME=ngo_documents
CHROMA_PERSIST_DIRECTORY=chroma_data

# Retrieval
RETRIEVAL_RESULT_COUNT=4
# Chroma uses L2 distance for this collection; lower values are more relevant.
RETRIEVAL_MAX_DISTANCE=0.9

# Agent safety limit
AGENT_MAX_TOOL_ITERATIONS=2
# Total ordered application-tool calls allowed in one user turn
AGENT_MAX_TOOL_CALLS_PER_TURN=3
# Complete user/assistant turns retained in process memory
AGENT_MEMORY_MAX_TURNS=10

# Approved read-only external weather API
EXTERNAL_API_TIMEOUT_SECONDS=5
EXTERNAL_API_MAX_RETRIES=2

# Read-only local SQL Server access (Windows Authentication)
SQL_SERVER=YEABSIRA
SQL_DATABASE=NGO_RAG
SQL_DRIVER=ODBC Driver 18 for SQL Server
SQL_TRUSTED_CONNECTION=true
SQL_TRUST_SERVER_CERTIFICATE=true
SQL_QUERY_TIMEOUT_SECONDS=10
SQL_MAX_ROWS=100
