OPENAI_API_KEY=your-openai-api-key

# OpenAI models
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_LLM_MODEL=gpt-4.1-mini

# Application logging
LOG_LEVEL=INFO

# Document ingestion
DOCUMENT_PATH=data/samples/sample_document.pdf
CHUNK_SIZE=800
CHUNK_OVERLAP=150

# ChromaDB
CHROMA_COLLECTION_NAME=ngo_documents
CHROMA_PERSIST_DIRECTORY=chroma_data

# Retrieval
RETRIEVAL_RESULT_COUNT=4
# Chroma uses L2 distance for this collection; lower values are more relevant.
RETRIEVAL_MAX_DISTANCE=0.9

# Agent safety limit
AGENT_MAX_TOOL_ITERATIONS=2
